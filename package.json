{
  "name": "@kosovopay/server-sdk",
  "version": "0.2.0",
  "description": "Type-safe, runtime-agnostic server SDK for the KosovoPay payment orchestrator. Runs on Node, Bun, Deno, and Cloudflare Workers — zero dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "shkumbinhasani",
  "homepage": "https://pay.kosovo.sh/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kosovopay/js-server-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/kosovopay/js-server-sdk/issues"
  },
  "keywords": [
    "kosovopay",
    "payments",
    "payment-orchestrator",
    "stripe-like",
    "cloudflare-workers",
    "bun",
    "webhooks",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun run scripts/fix-dts.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun test",
    "prepack": "bun run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
