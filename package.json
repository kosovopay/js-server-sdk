{
  "name": "kosovopay",
  "version": "0.1.0",
  "description": "Type-safe, runtime-agnostic SDK for the KosovoPay payment orchestrator. Runs on Node, Bun, Deno, and Cloudflare Workers — zero dependencies.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://pay.kosovo.sh/docs",
  "keywords": [
    "kosovopay",
    "payments",
    "payment-orchestrator",
    "stripe-like",
    "cloudflare-workers",
    "bun",
    "webhooks",
    "typescript"
  ],
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
